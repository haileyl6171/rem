# Copy to .env.local (never commit). Get Arize keys from app.arize.com → Space Settings → API Keys.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=
VOYAGE_API_KEY=

# Arize AX tracing (hackathon prize — sends spans to your hack-berkeley project)
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=hack-berkeley

# Anthropic — the LLM-as-judge evaluator (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
# EVALUATOR_MODEL=claude-haiku-4-5-20251001   # optional override

# Arize-driven retrieval quality cutoff: drop "find similar" neighbors below this
# cosine similarity. Chosen from the eval data; see ARIZE.md.
MEMORY_RELEVANCE_THRESHOLD=0.6
